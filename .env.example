# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# --- Launch handoff from the AA2000 portal ---
# 32-byte AES-GCM key shared with the portal (set the SAME value in the portal's
# VITE_LAUNCH_AES_KEY). Format: 64-char hex OR 32-byte standard base64.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Used to decrypt ?__launch=<sessionToken> and ?__actor=<accountId> on the launch URL.
# In dev only, leave this blank to derive the key from the dev string the portal also uses.
VITE_LAUNCH_AES_KEY=

# --- Portal backend API ---
# The portal's backend base URL (no trailing slash). KPI calls
# `GET <base>/session/:sessionToken` to resolve the launch token into the user.
# Multi/failover form: VITE_API_BASE_URLS=https://a.example.com,https://b.example.com
VITE_API_BASE_URL=
# VITE_API_BASE_URLS=

# Optional: API path prefix (e.g. /api). Leave blank if the API is at the root.
VITE_API_PREFIX=

# Optional: override session lookup path(s). The client tries these first, then
# falls back to /session, /security/session, /security/login/session, /api/session, /api/security/session.
# VITE_SESSION_LOOKUP_PATH=/security/session
# VITE_SESSION_LOOKUP_PATHS=/security/session,/api/security/session

# Optional: role_ID -> KPI role + department mapping for strict role-based behavior.
# JSON object where keys are portal role_ID values.
# Example:
# VITE_KPI_ROLE_ID_MAP={"1":{"appRole":"admin","department":"Admin"},"8":{"appRole":"employee","department":"Sales"}}
# appRole allowed values: admin | supervisor | employee
# If unset, KPI falls back to built-in defaults + role_name inference.
# VITE_KPI_ROLE_ID_MAP=

# Optional: backend KPI service base URL (used by AdminDashboard for criteria sync).
# Falls back to BACKEND_API_URL if VITE_BACKEND_API_URL is unset.
VITE_BACKEND_API_URL=
